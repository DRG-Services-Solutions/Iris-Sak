option_settings:
  aws:elasticbeanstalk:container:php:phpini:
    document_root: /public
    memory_limit: 512M

container_commands:
  01_create_storage_structure:
    command: |
      mkdir -p storage/framework/cache/data
      mkdir -p storage/framework/sessions  
      mkdir -p storage/framework/views
      mkdir -p storage/framework/testing
      mkdir -p storage/logs
      mkdir -p storage/app/public
      mkdir -p bootstrap/cache
      touch storage/logs/laravel.log
      echo "Carpetas creadas en $(pwd)"
      ls -la storage/framework/
    cwd: /var/app/staging
  02_set_permissions:
    command: |
      chmod -R 775 storage bootstrap/cache
      chown -R webapp:webapp storage bootstrap/cache
      echo "Permisos configurados"
      ls -la storage/framework/views
    cwd: /var/app/staging
  03_install_composer:
    command: "export COMPOSER_HOME=/root && /usr/bin/composer.phar install --no-dev --optimize-autoloader --no-interaction"
    cwd: /var/app/staging
    leader_only: true
  04_clear_caches:
    command: |
      php artisan view:clear || true
      php artisan config:clear || true
      php artisan cache:clear || true
    cwd: /var/app/staging
    leader_only: true