option_settings:
  aws:elasticbeanstalk:container:php:phpini:
    document_root: /public
    memory_limit: 256M
  aws:elasticbeanstalk:application:environment:
    APP_ENV: production
    APP_DEBUG: false
    LOG_CHANNEL: stderr

container_commands:
  01_install_composer_dependencies:
    command: "export COMPOSER_HOME=/root && /usr/bin/composer.phar install --no-dev --optimize-autoloader"
  02_run_migrations:
    command: "php artisan migrate --force"
    leader_only: true
  03_cache_config:
    command: "php artisan config:cache"
  04_cache_routes:
    command: "php artisan route:cache"
  05_cache_views:
    command: "php artisan view:cache"